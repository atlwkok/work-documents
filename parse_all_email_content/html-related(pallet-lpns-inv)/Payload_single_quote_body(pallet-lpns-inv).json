// ALL
{
    "alertName":"Pallet Lpns W/ Inventory Records",
    "dataSource":"MAWM",
    "database":{
        "connection":"MAPRD_NEW",
        "type":"MySQL",
        "uri":"jdbc:{host}:{port}/information_schema"
    },
    "email":{
        "subject":"Splunk Alert: $name$",
        "body":"<pre>The alert condition for ''$name$'' was triggered.<br />Manhattan case number 8269244<br /> <br />***MSP TO CLEAN UP***</pre>",
        "fromEmail":"wms-tools-noreply@rndc-usa.com",
        "toEmail":"WMSInternal@rndc-usa.com, WMSConsultant@rndc-usa.com, mcurtis@manh.com, WMSMSPSupport@RNDC-USA.COM, DL_RNDC_MAWM_CSO@manh.com, DL_MANH_RNDC_MAWM_PSO@manh.com",
        "ccEmail":"",
        "footer":"",
        "attachment":["link-to-alert","link-to-results", "inline-table"]
    },
    "sql":"select INV.ORG_ID, L.STATUS, L.PARENT_LPN_ID as ''PALLET'', INV.ON_HAND AS ''PLT_QTY'', INV.ALLOCATED AS ''PLT_ALLOCATED_QTY'', INV.TO_BE_FILLED AS ''PLT_TBF'', INV.LOCATION_ID AS ''PLT_LOCATION'', L.ILPN_ID AS ''CHILD_LPN'', INV.ITEM_ID from default_dcinventory.DCI_INVENTORY INV LEFT JOIN default_dcinventory.DCI_ILPN L ON L.PARENT_LPN_ID = INV.ILPN_ID AND L.ORG_ID = INV.ORG_ID where L.PARENT_LPN_ID IN (SELECT ILPN_ID FROM default_dcinventory.DCI_INVENTORY) and L.PARENT_LPN_ID IN (SELECT ILPN_ID FROM default_dcinventory.DCI_ILPN where status not in (''9000'',''11000''));"
}










