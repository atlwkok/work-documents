    },
    "sql":"SELECT * FROM   (SELECT ''IND'' AS ''WHSE'', CASE WHEN Count(*) = ''0'' THEN ''MISSING DFLT STATIC ROUTE VALUE'' ELSE ''OK'' END   AS ''STATUS'' FROM   (SELECT static_route_id, profile_id FROM   default_routing.RTG_STATIC_ROUTE WHERE  static_route_id = ''DFLT'' AND profile_id = concat($orgId, ''_Org_Profile''))A)B WHERE  status <> ''OK'';"
